# Plugin Marketplace Configuration

# Local plugin repository path (relative to backend directory)
PLUGINS_REPO_PATH=../plugins-repo

# Remote Git repository URL (for Claude Code client installation)
# Users can change this to their own repository
PLUGINS_REPO_URL=https://github.com/lizz0725/cc-plugin-marketplace.git

# Marketplace display name
MARKETPLACE_NAME=CC插件市场

# Admin emails (comma-separated)
ADMIN_EMAILS=

# Server settings
HOST=0.0.0.0
PORT=8000
DEBUG=false